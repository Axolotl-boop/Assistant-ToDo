# --- Anthropic (SERVEUR UNIQUEMENT — ne jamais exposer côté client) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Authentification (mot de passe unique) ---
APP_PASSWORD=change-me

# --- Base de données (fourni par Vercel Postgres) ---
POSTGRES_URL=postgres://...

# --- Secret pour signer le cookie de session ---
# Générer par ex avec : openssl rand -hex 32
SESSION_SECRET=change-me-long-random-string
